FROM python:3.13.13-alpine AS build 
ADD . /ec2
WORKDIR /ec2
RUN pip3 install --prefix=/devops -r requirments.txt

FROM python:3.13.13-alpine AS runtime
LABEL proejct ="python"
LABEL author ="Dileepmallekedi"
COPY --from=build /ec2 /app
COPY --from=build /devops /usr/local
WORKDIR /app
EXPOSE 50001    
CMD ["python3", "app.py"]