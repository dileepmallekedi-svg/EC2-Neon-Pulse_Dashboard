FROM python:3.13.13-slim AS build 
ADD . /ec2
WORKDIR /ec2
RUN pip3 install --prefix=/devops -r requirements.txt

FROM python:3.13.13-slim AS runtime
LABEL project ="python"
LABEL author ="Dileepmallekedi"
COPY --from=build /ec2 /app
COPY --from=build /devops /usr/local
WORKDIR /app
EXPOSE 5001    
CMD ["python3", "app.py"]